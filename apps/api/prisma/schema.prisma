// Tasku data model — covers Tier 1 (core) + Tier 2 (agile, workflows, labels,
// components, attachments, notifications). See docs/ARCHITECTURE.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users & membership
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships   ProjectMember[]
  reportedIssues Issue[]        @relation("Reporter")
  assignedIssues Issue[]        @relation("Assignee")
  comments      Comment[]
  activities    ActivityLog[]
  notifications Notification[]   @relation("Recipient")
  ledProjects   Project[]        @relation("ProjectLead")
  teamMemberships TeamMember[]
  watching      Watcher[]
  worklogs      Worklog[]
  savedFilters  SavedFilter[]
  boardStars    BoardStar[]
  knowledgeDocs KnowledgeDoc[]
}

enum Role {
  ADMIN
  MEMBER
  VIEWER
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

// ---------------------------------------------------------------------------
// Projects, workflows, statuses
// ---------------------------------------------------------------------------

model Project {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "TASK" -> issues TASK-1, TASK-2
  name        String
  description String?
  leadId      String?
  issueSeq    Int      @default(0) // per-project monotonic counter
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead       User?           @relation("ProjectLead", fields: [leadId], references: [id])
  members    ProjectMember[]
  issues     Issue[]
  statuses   Status[]
  sprints    Sprint[]
  labels     Label[]
  components Component[]
  boards     Board[]
  customFields CustomFieldDefinition[]
  versions   Version[]
}

enum StatusCategory {
  TODO
  IN_PROGRESS
  DONE
}

model Status {
  id        String         @id @default(cuid())
  projectId String
  name      String
  category  StatusCategory @default(TODO)
  order     Int            // column order on the board
  wipLimit  Int?           // optional work-in-progress limit for the column

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  Issue[]

  @@unique([projectId, name])
}

// ---------------------------------------------------------------------------
// Issues
// ---------------------------------------------------------------------------

enum IssueType {
  IDEA
  EPIC
  STORY
  TASK
  BUG
  SUBTASK
}

enum Priority {
  LOWEST
  LOW
  MEDIUM
  HIGH
  HIGHEST
}

model Issue {
  id          String    @id @default(cuid())
  projectId   String
  key         String    @unique // "TASK-42"
  seq         Int       // 42
  type        IssueType @default(TASK)
  title       String
  description String?   // rich text (HTML/JSON from TipTap)
  statusId    String
  priority    Priority  @default(MEDIUM)
  reporterId  String
  assigneeId  String?
  parentId    String?   // epic link / subtask parent
  sprintId    String?
  teamId      String?
  storyPoints Int?
  originalEstimate Int? // minutes; logged time = sum of worklogs
  startDate   DateTime? // timeline / roadmap
  dueDate     DateTime? // timeline / roadmap
  rank        String    // lexorank for board ordering
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status      Status        @relation(fields: [statusId], references: [id])
  reporter    User          @relation("Reporter", fields: [reporterId], references: [id])
  assignee    User?         @relation("Assignee", fields: [assigneeId], references: [id])
  team        Team?         @relation(fields: [teamId], references: [id])
  parent      Issue?        @relation("IssueHierarchy", fields: [parentId], references: [id])
  children    Issue[]       @relation("IssueHierarchy")
  sprint      Sprint?       @relation(fields: [sprintId], references: [id])
  comments    Comment[]
  labels      IssueLabel[]
  components   IssueComponent[]
  attachments Attachment[]
  activities  ActivityLog[]
  outLinks    IssueLink[]   @relation("LinkSource")
  inLinks     IssueLink[]   @relation("LinkTarget")
  watchers    Watcher[]
  worklogs    Worklog[]
  customValues CustomFieldValue[]
  versions    Version[]         @relation("IssueVersions")
  knowledgeDocs KnowledgeDoc[]

  @@index([projectId])
  @@index([statusId])
  @@index([sprintId])
  @@index([teamId])
  @@index([parentId])
}

enum LinkType {
  BLOCKS
  IS_BLOCKED_BY
  RELATES_TO
  DUPLICATES
  DELIVERS
  DELIVERED_BY
}

model IssueLink {
  id       String   @id @default(cuid())
  sourceId String
  targetId String
  type     LinkType @default(RELATES_TO)

  source Issue @relation("LinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Issue @relation("LinkTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, type])
}

// ---------------------------------------------------------------------------
// Sprints
// ---------------------------------------------------------------------------

enum SprintState {
  FUTURE
  ACTIVE
  CLOSED
}

model Sprint {
  id        String      @id @default(cuid())
  projectId String
  name      String
  goal      String?
  state     SprintState @default(FUTURE)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  Issue[]
}

// ---------------------------------------------------------------------------
// Labels & components
// ---------------------------------------------------------------------------

model Label {
  id        String @id @default(cuid())
  projectId String
  name      String
  color     String @default("#6b7280")

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  IssueLabel[]

  @@unique([projectId, name])
}

model IssueLabel {
  issueId String
  labelId String

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([issueId, labelId])
}

model Component {
  id        String @id @default(cuid())
  projectId String
  name      String

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  IssueComponent[]

  @@unique([projectId, name])
}

model IssueComponent {
  issueId     String
  componentId String

  issue     Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  component Component @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@id([issueId, componentId])
}

// ---------------------------------------------------------------------------
// Comments, attachments, activity, notifications
// ---------------------------------------------------------------------------

model Comment {
  id        String   @id @default(cuid())
  issueId   String
  authorId  String
  parentId  String? // one-level reply thread (a reply's parent is a top-level comment)
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issue   Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([issueId])
  @@index([parentId])
}

model Attachment {
  id         String   @id @default(cuid())
  issueId    String
  filename   String
  url        String
  mimeType   String
  size       Int
  uploadedAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  issueId   String
  actorId   String
  field     String   // e.g. "status", "assignee", "created", "comment"
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actor User  @relation(fields: [actorId], references: [id])

  @@index([issueId])
}

enum NotificationType {
  ASSIGNED
  MENTIONED
  COMMENTED
  STATUS_CHANGED
}

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  type        NotificationType
  issueKey    String
  message     String
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  recipient User @relation("Recipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, read])
}

// ---------------------------------------------------------------------------
// Teams
// ---------------------------------------------------------------------------

enum TeamRole {
  LEAD
  MEMBER
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())

  members TeamMember[]
  issues  Issue[]
  boards  Board[]
  knowledgeDocs KnowledgeDoc[]
}

model TeamMember {
  id     String   @id @default(cuid())
  teamId String
  userId String
  role   TeamRole @default(MEMBER)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

// ---------------------------------------------------------------------------
// Boards — a project can have several boards (a default board plus
// team-scoped / filtered boards). Columns are the project's statuses;
// `filter` narrows which issues appear (assignees, labels, types, priorities).
// ---------------------------------------------------------------------------

enum BoardType {
  KANBAN
  SCRUM
}

enum BoardSwimlane {
  NONE
  ASSIGNEE
  EPIC
  TEAM
  PRIORITY
}

model Board {
  id         String        @id @default(cuid())
  projectId  String
  name       String
  type       BoardType     @default(KANBAN)
  teamId     String?
  filter     Json?         // { assigneeIds?, labelIds?, types?, priorities? }
  swimlaneBy BoardSwimlane @default(NONE)
  isDefault  Boolean       @default(false)
  createdAt  DateTime      @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team    Team?   @relation(fields: [teamId], references: [id])
  stars   BoardStar[]

  @@index([projectId])
}

// A user's starred/favourite boards.
model BoardStar {
  id        String   @id @default(cuid())
  boardId   String
  userId    String
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Watchers, worklogs (time tracking), saved filters
// ---------------------------------------------------------------------------

model Watcher {
  id        String   @id @default(cuid())
  issueId   String
  userId    String
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([issueId, userId])
}

model Worklog {
  id        String   @id @default(cuid())
  issueId   String
  userId    String
  minutes   Int
  comment   String?
  startedAt DateTime @default(now())
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([issueId])
}

model SavedFilter {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  criteria  Json // { text?, projectKey?, statusIds?, assigneeIds?, types?, priorities?, teamIds?, labelIds? }
  shared    Boolean  @default(false)
  createdAt DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

// ---------------------------------------------------------------------------
// Custom fields — project-defined fields shown beside the built-in ones.
// SELECT/MULTI_SELECT carry their option list in `options` (a JSON string[]).
// A value is stored as JSON so one column fits every type.
// ---------------------------------------------------------------------------

enum CustomFieldType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  CHECKBOX
  SELECT
  MULTI_SELECT
  USER
  URL
}

model CustomFieldDefinition {
  id        String          @id @default(cuid())
  projectId String
  name      String
  type      CustomFieldType
  options   Json? // string[] for SELECT / MULTI_SELECT
  required  Boolean         @default(false)
  order     Int             @default(0)
  createdAt DateTime        @default(now())

  project Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  values  CustomFieldValue[]

  @@unique([projectId, name])
  @@index([projectId])
}

model CustomFieldValue {
  id      String @id @default(cuid())
  fieldId String
  issueId String
  value   Json // string | number | boolean | string[] | ISO date | userId

  field CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  issue Issue                 @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([fieldId, issueId])
  @@index([issueId])
}

// ---------------------------------------------------------------------------
// Versions / releases — an issue's fixVersions (many-to-many). A version's
// delivery progress is derived from its issues' status categories.
// ---------------------------------------------------------------------------

model Version {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  description String?
  released    Boolean   @default(false)
  startDate   DateTime?
  releaseDate DateTime?
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  Issue[] @relation("IssueVersions")

  @@unique([projectId, name])
  @@index([projectId])
}

// ---------------------------------------------------------------------------
// Knowledge base — a doc (uploaded FILE or external LINK, e.g. a Google Doc /
// Sheet) owned by exactly one Team OR one Issue. Issues inherit their
// ancestors' docs (computed at read time, ancestors-only). A doc can be
// imported into another KB as a live reference (isImport + importedFromId) —
// its content resolves from the source doc.
// ---------------------------------------------------------------------------

enum KnowledgeType {
  FILE
  LINK
}

enum KnowledgeLinkKind {
  GOOGLE_DOC
  GOOGLE_SHEET
  GOOGLE_SLIDES
  GENERIC
}

model KnowledgeDoc {
  id       String            @id @default(cuid())
  title    String
  type     KnowledgeType

  // LINK docs
  url      String?
  linkKind KnowledgeLinkKind?

  // FILE docs — bytes on disk as `${id}${ext}`, streamed via /knowledge/:id/raw
  filename String?
  mimeType String?
  size     Int?

  // Owner: exactly one of teamId / issueId is set.
  teamId  String?
  issueId String?

  // Live import: a reference to a doc in another KB (content resolves from it).
  isImport       Boolean @default(false)
  importedFromId String?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team         Team?          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  issue        Issue?         @relation(fields: [issueId], references: [id], onDelete: Cascade)
  importedFrom KnowledgeDoc?  @relation("KnowledgeImport", fields: [importedFromId], references: [id], onDelete: SetNull)
  imports      KnowledgeDoc[] @relation("KnowledgeImport")
  createdBy    User           @relation(fields: [createdById], references: [id])

  @@index([teamId])
  @@index([issueId])
  @@index([importedFromId])
}
