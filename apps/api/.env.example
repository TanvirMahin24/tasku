DATABASE_URL="postgresql://tasku:tasku@localhost:5432/tasku?schema=public"
JWT_SECRET="change-me"
PORT=4000
WEB_ORIGIN="http://localhost:5173"
# Directory where uploaded attachment bytes are stored (created if missing).
UPLOAD_DIR="uploads"

# --- Majhi AI assistant ---
# Provider auto-detects: if GEMINI_API_KEY is set -> gemini; else if Ollama
# reachable -> ollama. Set AI_PROVIDER to force one.
AI_PROVIDER=            # "" (auto) | ollama | gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBED_MODEL=text-embedding-004
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text
# Google Docs/Sheets/Slides OAuth (for the knowledge base)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=http://localhost:4000/api/v1/ai/google/callback
